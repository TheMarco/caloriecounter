# Environment variables for the Calorie Tracker web project (marketing page + the
# iOS app's API backend). Copy to .env.local and fill in real values.

# ── OpenAI (required for the proxy) ─────────────────────────────────────────
# Food/photo parsing. Get a key at https://platform.openai.com/api-keys
# IMPORTANT: set a hard monthly budget cap on the key (Platform ▸ Settings ▸
# Limits) — that's the real protection for your bill.
OPENAI_API_KEY="your-openai-api-key-here"

# ── App Attest token signing (required) ─────────────────────────────────────
# HMAC secret used to sign/verify the short-lived bearer tokens the iOS app gets
# after attestation. Use a long random string. ATTEST_JWT_SECRET takes precedence;
# NEXTAUTH_SECRET is the fallback.
ATTEST_JWT_SECRET="a-long-random-secret"
NEXTAUTH_SECRET="a-long-random-secret"

# App Attest identity. Defaults match this app; override only if they change.
APP_ATTEST_TEAM_ID="3ML6V62AF5"
APP_ATTEST_BUNDLE_ID="com.aidashcreated.caloriecounter"
# Accept Apple "development" attestations (Xcode/dev builds, TestFlight). Set to
# "false" to require production attestations only.
APP_ATTEST_ALLOW_DEV="true"

# ── Upstash Redis (required in production) ──────────────────────────────────
# Stores device public keys, one-time challenges, and rate-limit counters.
# Provision via Vercel ▸ Marketplace ▸ Upstash. If unset, the backend falls back
# to a non-durable in-memory store (fine for local `npm run dev` only).
# NOTE: the Vercel Upstash/KV integration injects KV_REST_API_URL /
# KV_REST_API_TOKEN instead — the code reads those automatically too, so you don't
# need to duplicate them under the UPSTASH_* names.
UPSTASH_REDIS_REST_URL="https://your-db.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# Optional: per-device MONTHLY spend cap in USD (default 2.00). The proxy tracks
# each device's real OpenAI cost (from token usage) and refuses calls once a device
# hits this for the calendar month. Bounds worst-case cost per user.
# OPENAI_MONTHLY_BUDGET_PER_DEVICE="2.00"
# Optional: per-device daily call ceiling on the proxy (default 300).
# PROXY_DAILY_DEVICE_LIMIT="300"
# Optional: bearer token lifetime in seconds (default 1800 = 30 min).
# ATTEST_TOKEN_TTL_SECONDS="1800"

# ── Local development only ──────────────────────────────────────────────────
# The iOS Simulator can't perform App Attest. Set this to a shared secret and run
# the app (DEBUG) with the same value in ATTEST_DEV_BYPASS to obtain a token
# without attestation. Honored ONLY when NODE_ENV != production — NEVER set it in
# the production environment.
# ATTEST_DEV_BYPASS="some-dev-only-secret"
